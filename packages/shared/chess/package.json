{
  "name": "@yourcompany/chess",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#*": "./src/*.ts"
  },
  "exports": {
    "./types": "./src/types.ts",
    "./constants": "./src/constants.ts",
    "./graph": "./src/graph-algo.ts",
    "./edge-weights": "./src/edge-weights.ts",
    "./community": "./src/community.ts",
    "./community-lineage": "./src/community-lineage.ts",
    "./centrality": "./src/centrality.ts",
    "./engine": "./src/engine.ts",

    "./opening-db/ecoDatabase": "./src/opening-db/ecoDatabase.ts"
  },
  "sideEffects": false,
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc",
    "lint": "biome lint --fix ./src",
    "lint:check": "biome lint ./src",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "chess.js": "^1.0.0-beta.8",
    "neverthrow": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@yourcompany/configs": "workspace:*",
    "vitest": "catalog:"
  }
}
