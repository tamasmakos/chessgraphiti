---
import BaseLayout from "../layouts/BaseLayout.astro";
import { LINKS, SITE } from "../lib/site";
---

<BaseLayout title={`${SITE.title} — Chess you can see.`} description={SITE.description}>
  <header class="container site-header">
    <div class="site-header__inner">
      <a href="/" style="display:flex; align-items:center; gap: 10px;">
        <span style="font-weight: 900; letter-spacing: -0.04em; font-size: 1.1rem;">ChessGraphiti</span>
      </a>

      <nav aria-label="Primary" class="btn-row">
        <a class="btn ghost" href="#how-it-works">How it works</a>
        <a class="btn" href={LINKS.app}>Play Free</a>
      </nav>
    </div>
  </header>

  <main id="content" class="container">

    <!-- Hero -->
    <section class="section hero">
      <div class="hero-content">
        <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(105,233,255,0.08); border:1px solid rgba(105,233,255,0.2); border-radius:999px; padding:4px 14px; margin-bottom:20px;">
          <span style="width:6px;height:6px;border-radius:50%;background:var(--accent);display:inline-block;"></span>
          <span style="font-size:0.72rem; font-weight:700; color:var(--accent); letter-spacing:0.06em; text-transform:uppercase;">Now in early access</span>
        </div>

        <h1 class="hero-title">Chess&nbsp;you&nbsp;can&nbsp;see.</h1>

        <p class="hero-lead">
          Stop memorizing moves. Start understanding why positions are strong.
          Every piece is a node, every attack and defence a live edge —
          ChessGraphiti makes chess structure visible.
        </p>

        <div class="btn-row hero-cta">
          <a class="btn primary" href={LINKS.app}>Play Free — No Sign Up Needed</a>
          <a class="btn" href="#how-it-works">See how it works</a>
        </div>

        <p style="margin-top:16px; font-size:0.78rem; color:var(--muted2);">
          Built for players at 1200–1800 who know the theory but don't yet feel the position.
        </p>
      </div>

      <!-- Graph demo visual -->
      <div class="card card--terminal hero-terminal" style="overflow:hidden;">
        <div class="terminal-bar" aria-hidden="true">
          <span class="terminal-dot dot-red"></span>
          <span class="terminal-dot dot-yellow"></span>
          <span class="terminal-dot dot-green"></span>
          <span class="terminal-title">live board — Ruy Lopez after 9 moves</span>
        </div>
        <div style="padding:24px; display:flex; flex-direction:column; gap:12px;">
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
            <div style="background:rgba(105,233,255,0.06); border:1px solid rgba(105,233,255,0.15); border-radius:10px; padding:12px;">
              <div style="font-size:0.65rem; font-weight:800; color:var(--accent); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;">Graph nodes</div>
              <div style="font-size:1.4rem; font-weight:900; color:var(--text);">28</div>
              <div style="font-size:0.7rem; color:var(--muted2);">active pieces</div>
            </div>
            <div style="background:rgba(139,92,246,0.06); border:1px solid rgba(139,92,246,0.2); border-radius:10px; padding:12px;">
              <div style="font-size:0.65rem; font-weight:800; color:var(--accent2); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;">Graph edges</div>
              <div style="font-size:1.4rem; font-weight:900; color:var(--text);">94</div>
              <div style="font-size:0.7rem; color:var(--muted2);">attack + defence links</div>
            </div>
          </div>
          <div style="background:rgba(34,197,94,0.06); border:1px solid rgba(34,197,94,0.15); border-radius:10px; padding:12px;">
            <div style="font-size:0.65rem; font-weight:800; color:var(--accent3); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;">Communities detected</div>
            <div style="display:flex; gap:6px; flex-wrap:wrap;">
              <span style="background:rgba(239,68,68,0.2);color:#fca5a5;border-radius:6px;padding:2px 8px;font-size:0.7rem;font-weight:700;">Red — e5 cluster (4 pieces)</span>
              <span style="background:rgba(59,130,246,0.2);color:#93c5fd;border-radius:6px;padding:2px 8px;font-size:0.7rem;font-weight:700;">Blue — queenside (5 pieces)</span>
              <span style="background:rgba(139,92,246,0.2);color:#c4b5fd;border-radius:6px;padding:2px 8px;font-size:0.7rem;font-weight:700;">Purple — kingside (6 pieces)</span>
            </div>
          </div>
          <div style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:10px; padding:12px;">
            <div style="font-size:0.65rem; font-weight:800; color:var(--muted); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;">Most influential piece</div>
            <div style="font-size:0.9rem; font-weight:700; color:var(--text);">♞ Nf3 — betweenness 0.87</div>
            <div style="font-size:0.7rem; color:var(--muted2);">bridges the e5 cluster and kingside coalition</div>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section id="how-it-works" class="section">
      <h2>Why you keep losing positions you've studied</h2>
      <p class="lead">
        Traditional chess tools show you <em>what</em> to play. ChessGraphiti shows you <em>why</em> it works.
        The graph makes the invisible structure of a position visible — in real time, as you play.
      </p>

      <div class="grid cols-3">
        <div class="card">
          <h3>Live attack &amp; defence graph</h3>
          <p>
            Every relationship between pieces renders as a directed, weighted edge on the board.
            Move a piece — the graph reacts instantly. See pressure build and collapse.
          </p>
        </div>
        <div class="card">
          <h3>Piece community detection</h3>
          <p>
            Graph clustering groups pieces into coalitions that actually cooperate.
            Watch alliances form, fracture, and shift as the game evolves — not visible any other way.
          </p>
        </div>
        <div class="card">
          <h3>Structural influence (centrality)</h3>
          <p>
            Centrality metrics reveal which pieces are most important — not by material value,
            but by how much of the position runs through them. A knight on f3 often outranks a rook on a1.
          </p>
        </div>
      </div>
    </section>

    <!-- Who it's for -->
    <section class="section">
      <h2>Built for the 1200–1800 wall</h2>
      <p class="lead">
        If you can recite the Ruy Lopez but still lose to it — this is for you.
        The gap isn't knowledge. It's intuition. ChessGraphiti builds it.
      </p>

      <div class="grid cols-2">
        <div class="card">
          <h3>Opening trainer</h3>
          <p>
            Drill any opening and watch the graph evolve move-by-move. Understand
            <em>why</em> the Ruy Lopez is good, not just that it is.
          </p>
        </div>
        <div class="card">
          <h3>Post-game analysis</h3>
          <p>
            Step through your game with full graph replay. See exactly when you lost structural
            control — before the material was ever down.
          </p>
        </div>
        <div class="card">
          <h3>GNN move tutor</h3>
          <p>
            A graph neural network trained on master games ranks candidate moves by position structure,
            not just engine evaluation. Understand the logic, not just the verdict.
          </p>
        </div>
        <div class="card">
          <h3>Export as graph reel</h3>
          <p>
            Turn any game into an animated graph video. Share your best game showing exactly
            how the position evolved — a format no other chess tool offers.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section id="get-started" class="section" style="text-align:center; padding-bottom:80px;">
      <h2>Start seeing the position</h2>
      <p class="lead" style="max-width:480px; margin-inline:auto;">
        No sign-up required to play. The graph is live on your first move.
      </p>
      <div class="btn-row" style="justify-content:center; margin-top:24px;">
        <a class="btn primary" href={LINKS.app} style="font-size:1rem; padding:14px 32px;">
          Open the Board — Free
        </a>
      </div>
      <p style="margin-top:16px; font-size:0.78rem; color:var(--muted2);">
        <a href={LINKS.twitter} target="_blank" rel="noreferrer" style="color:var(--muted);">Follow on Twitter</a>
        &nbsp;·&nbsp;
        <a href={`mailto:${LINKS.email}`} style="color:var(--muted);">Get in touch</a>
      </p>
    </section>

  </main>
</BaseLayout>

    <section class="section hero">
      <div class="hero-content">
        <h1 class="hero-title">Build fast with a clean, pragmatic stack.</h1>

        <p class="hero-lead">
          A modern TypeScript monorepo template that gets you to "shipping" quickly: predictable structure, sane tooling, and a backend/frontend split that scales without getting in your way.
        </p>

        <div class="btn-row hero-cta">
          <a class="btn primary" href={LINKS.github} target="_blank" rel="noreferrer">View repo</a>
          <a class="btn" href="#get-started">Quick start</a>
        </div>
      </div>

      <div class="card card--terminal hero-terminal">
        <div class="terminal-bar" aria-hidden="true">
          <span class="terminal-dot dot-red"></span>
          <span class="terminal-dot dot-yellow"></span>
          <span class="terminal-dot dot-green"></span>
          <span class="terminal-title">repo preview</span>
        </div>
        <pre><code>frm-stack/
  apps/
    backend/api        # API service
    frontend/web       # product app
    frontend/landing   # Astro landing
  packages/
    backend/core       # backend libs
    frontend/web       # web libs
    shared/config      # shared tooling

# get started with
> just setup
> pnpm dev</code></pre>
      </div>
    </section>

    <section class="section">
      <h2>Why this template</h2>
      <p class="lead">A baseline that stays tidy as you add apps, packages, and teams.</p>

      <div class="grid cols-3">
        <div class="card">
          <h3>Monorepo that stays tidy</h3>
          <p>Turbo + pnpm workspaces/catalog for consistent versions and fast tasks across apps and packages.</p>
        </div>
        <div class="card">
          <h3>Backend + DB workflow</h3>
          <p>Postgres-ready, schema-first approach, and a structure that keeps service boundaries clear.</p>
        </div>
        <div class="card">
          <h3>Frontend ready to grow</h3>
          <p>Composable UI patterns and tooling that keeps DX high while still being maintainable long-term.</p>
        </div>
      </div>
    </section>

    <section id="get-started" class="section">
      <h2>Get started</h2>
      <p class="lead">Clone the template, install deps, and start the dev servers. Then tweak what you need.</p>

      <div class="grid cols-2">
        <div class="card">
          <h3>1. Clone + install</h3>
          <pre><code>git clone {GET_STARTED.cloneHttps}
cd frm-stack
pnpm install</code></pre>
        </div>

        <div class="card">
          <h3>2. Setup + run dev</h3>
          <pre><code># from the repo root
just setup
pnpm dev</code></pre>
        </div>
      </div>
    </section>

    <section class="section">
      <h2>What you get</h2>
      <p class="lead">A clean baseline you can adapt: swap libraries, keep the structure, and move quickly.</p>

      <div class="grid cols-3">
        <div class="card card--soft">
          <h3>Clear boundaries</h3>
          <p>Apps are separate from shared packages, so shared code stays intentional and easy to maintain.</p>
        </div>
        <div class="card card--soft">
          <h3>Fast feedback loops</h3>
          <p>JIT dev setup and task orchestration keep iteration fast, even as the repo grows.</p>
        </div>
        <div class="card card--soft">
          <h3>Sane defaults</h3>
          <p>Formatting and linting are centralized; TypeScript and modern tooling are first-class.</p>
        </div>
      </div>
    </section>

    <section id="contact" class="section section--end">
      <h2>Contact</h2>
      <p class="lead">Questions, feedback, or PRs welcome.</p>

      <div class="grid cols-3">
        <div class="card card--soft">
          <h3>Email</h3>
          <p><a href={mailto}>{LINKS.email}</a></p>
        </div>
        <div class="card card--soft">
          <h3>Twitter</h3>
          <p><a href={LINKS.twitter} target="_blank" rel="noreferrer">{LINKS.twitter}</a></p>
        </div>
        <div class="card card--soft">
          <h3>GitHub</h3>
          <p><a href={LINKS.github} target="_blank" rel="noreferrer">{LINKS.github}</a></p>
        </div>
      </div>
    </section>
  </main>

  <footer class="container site-footer">
    <div class="site-footer__inner">
      <span>© {new Date().getFullYear()} FRM Stack • Built with Astro</span>
      <span>
        <a href={LINKS.github} target="_blank" rel="noreferrer">Repo</a>
        <span aria-hidden="true"> · </span>
        <a href={mailto}>Email</a>
      </span>
    </div>
  </footer>
</BaseLayout>
